rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // POSTS:
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.authorName == request.auth.token.name);
    }

    // USERS:
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // GLOBAL STATS:
    match /global_stats/{docId} {
      allow read: if true;
      allow write: if isSignedIn(); // In a real app, restrict to server/admin
    }

    // SYSTEM LOGS:
    match /system_logs/{logId} {
      allow read: if isSignedIn(); // Only members can see system health
      allow create: if isSignedIn();
      allow update, delete: if false; // Logs are immutable
    }
  }
}