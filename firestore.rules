rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // POSTS:
    // - Read: Public
    // - Create: Any signed in user
    // - Update: Any signed in user (allows liking/commenting on others' posts)
    // - Delete: Only the author can delete
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.authorName == request.auth.token.name);
    }

    // USERS:
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}