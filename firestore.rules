rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    function isBoardOwner(boardId) {
      return isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.ownerId;
    }

    function isWorkspaceMember(workspaceId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberIds;
    }

    function isWorkspaceOwner(workspaceId) {
      return isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId;
    }

    // POSTS:
    // - Read: Public
    // - Create: Any signed in user
    // - Update: Any signed in user (allows liking/commenting on others' posts)
    // - Delete: Only the author can delete
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.authorName == request.auth.token.name);
    }

    // USERS:
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /boards/{boardId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.ownerId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;

      match /messages/{messageId} {
        allow read: if isBoardOwner(boardId);
        allow create: if isBoardOwner(boardId);
        allow update, delete: if false;
      }
    }

    match /workspaces/{workspaceId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if isWorkspaceOwner(workspaceId);
      allow delete: if isWorkspaceOwner(workspaceId);

      match /members/{memberId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow create, update, delete: if isWorkspaceOwner(workspaceId);
      }

      match /threads/{threadId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow create: if isWorkspaceMember(workspaceId)
          && request.auth.uid == request.resource.data.createdBy;
        allow update: if isWorkspaceMember(workspaceId);
        allow delete: if isWorkspaceOwner(workspaceId);

        match /messages/{messageId} {
          allow read: if isWorkspaceMember(workspaceId);
          allow create: if isWorkspaceMember(workspaceId)
            && request.auth.uid == request.resource.data.authorId;
          allow update, delete: if false;
        }
      }

      match /integrations/{integrationId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow create, update, delete: if isWorkspaceOwner(workspaceId);
      }

      match /tasks/{taskId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow create: if isWorkspaceMember(workspaceId)
          && request.auth.uid == request.resource.data.requestedBy;
        allow update, delete: if isWorkspaceOwner(workspaceId);
      }
    }
  }
}
